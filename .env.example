# DebugPilot Environment Variables
# Copy this file to .env.local and fill in your secrets

# Oxlo AI API Configuration (Required)
OXLO_API_KEY=""
OXLO_ENDPOINT="https://api.oxlo.ai/v1/chat/completions"
OXLO_MODEL="deepseek-v3.2"

# Slack Integration (Optional — "Notify Slack" button will be disabled if empty)
SLACK_WEBHOOK_URL=""
